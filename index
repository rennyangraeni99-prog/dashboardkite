<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KITE Dashboard - Google Sheets Integration</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0/dist/chartjs-plugin-datalabels.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Roboto, sans-serif; }
        body { background: #f0f2f5; padding: 20px 16px; }
        .container { max-width: 1400px; margin: 0 auto; }
        .header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 24px; gap: 12px; }
        h1 { font-size: 1.5rem; background: linear-gradient(135deg, #1e3c72, #2b4c7c); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .btn { background: #2b6cb0; color: white; border: none; padding: 8px 18px; border-radius: 40px; font-weight: 600; cursor: pointer; transition: 0.2s; }
        .btn:hover { opacity: 0.85; }
        .btn-danger { background: #dc2626; }
        .btn-refresh { background: #4b5563; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 14px; margin-bottom: 24px; }
        .stat-card { background: white; border-radius: 24px; padding: 12px 14px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #e9edf2; }
        .stat-number { font-size: 1.7rem; font-weight: 800; color: #1e293b; }
        .charts-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin-bottom: 24px; }
        .chart-card { background: white; border-radius: 22px; padding: 12px; border: 1px solid #e9edf2; }
        .chart-title { font-weight: 600; margin-bottom: 8px; border-left: 4px solid #3b82f6; padding-left: 10px; }
        .chart-container { width: 100%; height: 190px; }
        .search-bar { background: white; padding: 8px 16px; border-radius: 50px; border: 1px solid #e2e8f0; display: flex; gap: 10px; margin-bottom: 16px; }
        .search-bar input { flex: 1; border: none; outline: none; }
        .table-wrapper { overflow-x: auto; background: white; border-radius: 20px; border: 1px solid #ecf3fa; }
        table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
        th { background: #f8fafc; padding: 10px 6px; text-align: left; font-weight: 600; }
        td { padding: 8px 6px; border-bottom: 1px solid #f1f5f9; }
        tr { cursor: pointer; }
        tr:hover { background: #fefce8; }
        .badge { display: inline-block; padding: 3px 8px; border-radius: 40px; font-size: 0.65rem; font-weight: 600; }
        .badge-aktif { background: #dcfce7; color: #15803d; }
        .badge-cabut { background: #fee2e2; color: #b91c1c; }
        .badge-beku { background: #fff3e3; color: #b45309; }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; z-index: 1000; }
        .modal-content { background: white; border-radius: 28px; width: 90%; max-width: 850px; max-height: 85vh; overflow-y: auto; padding: 24px; }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .close { font-size: 28px; cursor: pointer; color: #64748b; }
        .close:hover { color: #ef4444; }
        .form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
        .form-field { display: flex; flex-direction: column; }
        .form-field label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; color: #64748b; }
        .form-field input { padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 20px; margin-top: 4px; font-size: 0.8rem; }
        .action-buttons { display: flex; gap: 8px; justify-content: flex-end; margin-top: 20px; }
        .loading { text-align: center; padding: 40px; color: #6c757d; }
        footer { text-align: center; font-size: 0.7rem; margin-top: 24px; color: #6c757d; }
        @media (max-width: 640px) { .form-grid { grid-template-columns: 1fr; } }
        .status-connected { background: #dcfce7; color: #15803d; padding: 4px 12px; border-radius: 40px; font-size: 0.7rem; }
        .status-disconnected { background: #fee2e2; color: #b91c1c; padding: 4px 12px; border-radius: 40px; font-size: 0.7rem; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div style="display: flex; align-items: center; gap: 12px;">
            <h1><i class="fas fa-chalkboard-user"></i> KITE DASHBOARD</h1>
            <div id="connectionStatus" class="status-disconnected"><i class="fas fa-plug"></i> Menghubungkan...</div>
        </div>
        <div style="display: flex; gap: 10px;">
            <button class="btn btn-refresh" id="refreshBtn"><i class="fas fa-sync-alt"></i> Refresh</button>
            <button class="btn" id="openAddBtn"><i class="fas fa-plus"></i> Tambah Data</button>
        </div>
    </div>
    
    <div class="stats-grid" id="statsCards"><div class="loading"><i class="fas fa-spinner fa-pulse"></i> Memuat data...</div></div>
    
    <div class="charts-row">
        <div class="chart-card"><div class="chart-title">Status Fasilitas</div><canvas id="statusChart" class="chart-container"></canvas></div>
        <div class="chart-card"><div class="chart-title">Top Sektor Industri</div><canvas id="sektorChart" class="chart-container"></canvas></div>
        <div class="chart-card"><div class="chart-title">Kantor Pengawas</div><canvas id="wilayahChart" class="chart-container"></canvas></div>
        <div class="chart-card"><div class="chart-title">Jenis NIPER</div><canvas id="niperChart" class="chart-container"></canvas></div>
    </div>
    
    <div class="search-bar">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" placeholder="Cari nama, kantor, atau SKEP...">
    </div>
    
    <div class="table-wrapper">
        <table>
            <thead><tr><th>Nama Perusahaan</th><th>Kantor Pengawas</th><th>Jenis NIPER</th><th>Status</th><th>Sektor</th><th>SKEP Awal</th><th>Aksi</th></tr></thead>
            <tbody id="tableBody"><tr><td colspan="7" class="loading"><i class="fas fa-spinner fa-pulse"></i> Mengambil data...</td></tr></tbody>
        </table>
    </div>
    <footer>Klik nama untuk detail. Edit/Hapus password: <strong>admin123</strong></footer>
</div>

<!-- Modal Detail -->
<div id="detailModal" class="modal"><div class="modal-content"><div class="modal-header"><h2 id="detailTitle">Detail</h2><span class="close" onclick="closeModal('detailModal')">&times;</span></div><div id="detailContent" class="form-grid"></div></div></div>

<!-- Modal Form -->
<div id="formModal" class="modal"><div class="modal-content"><div class="modal-header"><h2 id="formTitle">Form</h2><span class="close" onclick="closeModal('formModal')">&times;</span></div><div id="formFields" class="form-grid"></div><div class="action-buttons"><button class="btn" id="saveBtn">Simpan</button><button class="btn btn-danger" onclick="closeModal('formModal')">Batal</button></div></div></div>

<!-- Modal Password -->
<div id="passwordModal" class="modal"><div class="modal-content"><div class="modal-header"><h2>Verifikasi Password</h2><span class="close" onclick="closeModal('passwordModal')">&times;</span></div><div class="form-field"><label>Password</label><input type="password" id="adminPassword" placeholder="Masukkan password"></div><div class="action-buttons"><button class="btn" id="verifyPasswordBtn">Verifikasi</button></div></div></div>

<script>
    // ================= ⚠️ GANTI URL INI DENGAN WEB APP ANDA ⚠️ =================
    const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbz_1DEc4DHoFm7k3xPx5G0iRhb4cLdN7wQxYzU/exec";
    const ADMIN_PASSWORD = "admin123";
    
    let allData = [];
    let charts = {};
    let currentEditIndex = null;
    let pendingCallback = null;
    
    const ALL_COLUMNS = ["No","NPWP","Nama Perusahaan","Kantor Pengawas","Jenis NIPER","SKEP","Tanggal","SKEP PERUBAHAN TERAKHIR","Tanggal SKEP Perubahan Terakhir","NIB","Alamat Perusahaan","Nama Penanggung Jawab","Contact Perusahaan","Alamat Pabrik","Provinsi","Bidang Usaha Industri","Sektor Industri","Pengelompokan Bidang Usaha Industri","Hasil Produksi","KLU","Nama KLU","Golpok","Badan Usaha Penerima Subkon","Tahapan Kegiatan Produksi","CG","MITA","AEO","Riwayat Audit","Status","Tgl Beku","Tgl Cabut","History Beku","Pencabutan","Keterangan"];
    
    async function callApi(action, data = null, rowIndex = null) {
        const password = localStorage.getItem("kite_password") || "";
        const params = new URLSearchParams();
        params.append("action", action);
        params.append("password", password);
        if (data) { const payload = { ...data }; if (rowIndex !== null) payload._rowIndex = rowIndex; params.append("data", JSON.stringify(payload)); }
        else if (rowIndex !== null) params.append("data", JSON.stringify({ _rowIndex: rowIndex }));
        
        try {
            const response = await fetch(`${WEB_APP_URL}?${params.toString()}`, { method: "GET", mode: "cors" });
            return await response.json();
        } catch (error) { return { success: false, message: error.message }; }
    }
    
    async function loadData() {
        const result = await callApi("getData");
        if (result.success && result.data) { allData = result.data; renderAll(); updateConnectionStatus(true, `OK (${allData.length})`); }
        else { updateConnectionStatus(false, result.message); document.getElementById("tableBody").innerHTML = `<tr><td colspan="7" class="loading">Error: ${result.message}</td></tr>`; }
    }
    
    function updateConnectionStatus(ok, msg) {
        const el = document.getElementById("connectionStatus");
        el.className = ok ? "status-connected" : "status-disconnected";
        el.innerHTML = ok ? `<i class="fas fa-check-circle"></i> ${msg}` : `<i class="fas fa-exclamation-triangle"></i> ${msg}`;
    }
    
    function renderStats() {
        const aktif = allData.filter(d => d.Status === "Aktif").length;
        const cabut = allData.filter(d => d.Status === "Cabut").length;
        const beku = allData.filter(d => d.Status === "Beku").length;
        document.getElementById("statsCards").innerHTML = `
            <div class="stat-card"><div><h3>Total</h3><div class="stat-number">${allData.length}</div></div><i class="fas fa-building fa-2x"></i></div>
            <div class="stat-card"><div><h3>Aktif</h3><div class="stat-number">${aktif}</div></div><i class="fas fa-check-circle fa-2x" style="color:#2ecc71;"></i></div>
            <div class="stat-card"><div><h3>Cabut</h3><div class="stat-number">${cabut}</div></div><i class="fas fa-ban fa-2x" style="color:#e74c3c;"></i></div>
            <div class="stat-card"><div><h3>Beku</h3><div class="stat-number">${beku}</div></div><i class="fas fa-hourglass-half fa-2x" style="color:#f39c12;"></i></div>`;
    }
    
    function renderTable(filter = "") {
        const filtered = allData.filter(d => (d["Nama Perusahaan"]||"").toLowerCase().includes(filter.toLowerCase()) || (d["Kantor Pengawas"]||"").toLowerCase().includes(filter.toLowerCase()));
        document.getElementById("tableBody").innerHTML = filtered.map((d, idx) => {
            const oidx = allData.findIndex(x => x["Nama Perusahaan"] === d["Nama Perusahaan"]);
            let sc = d.Status === "Aktif" ? "badge-aktif" : (d.Status === "Cabut" ? "badge-cabut" : "badge-beku");
            return `<tr><td style="color:#2b6cb0;text-decoration:underline;cursor:pointer;" onclick='showDetail(${JSON.stringify(d).replace(/'/g,"&#39;")})'>${escapeHtml(d["Nama Perusahaan"]||"-")}</td>
                    <td>${escapeHtml(d["Kantor Pengawas"]||"-")}</td><td>${escapeHtml(d["Jenis NIPER"]||"-")}</td>
                    <td><span class="badge ${sc}">${d.Status||"-"}</span></td>
                    <td>${escapeHtml((d["Sektor Industri"]||"").substring(0,35))}</td>
                    <td>${escapeHtml(d["SKEP"]||"-")}</td>
                    <td><button class="btn" style="padding:4px 12px;" onclick='event.stopPropagation(); editData(${oidx})'>Edit</button>
                        <button class="btn btn-danger" style="padding:4px 12px;background:#dc2626;" onclick='event.stopPropagation(); confirmDelete(${oidx})'>Hapus</button></td></tr>`;
        }).join("");
    }
    
    function updateCharts() {
        const aktif = allData.filter(d=>d.Status==="Aktif").length, cabut = allData.filter(d=>d.Status==="Cabut").length, beku = allData.filter(d=>d.Status==="Beku").length;
        if(charts.status) charts.status.destroy();
        charts.status = new Chart(document.getElementById("statusChart"), { type:'pie', data:{ labels:['Aktif','Cabut','Beku'], datasets:[{ data:[aktif,cabut,beku], backgroundColor:['#2ecc71','#e74c3c','#f39c12'] }] }, options:{ plugins:{ datalabels:{ color:'white', formatter:(v)=>v } }, responsive:true }, plugins:[ChartDataLabels] });
        
        const sektorMap = new Map();
        allData.forEach(d=>{ let s=(d["Sektor Industri"]||"").split(",")[0]; if(s) sektorMap.set(s,(sektorMap.get(s)||0)+1); });
        const topSektor = Array.from(sektorMap.entries()).sort((a,b)=>b[1]-a[1]).slice(0,4);
        if(charts.sektor) charts.sektor.destroy();
        charts.sektor = new Chart(document.getElementById("sektorChart"), { type:'bar', data:{ labels:topSektor.map(s=>s[0].length>20?s[0].substring(0,17)+"...":s[0]), datasets:[{ label:'Jumlah', data:topSektor.map(s=>s[1]), backgroundColor:'#3b82f6' }] }, options:{ indexAxis:'y', plugins:{ datalabels:{ anchor:'end', align:'right', formatter:(v)=>v } }, responsive:true }, plugins:[ChartDataLabels] });
        
        const wilayahMap = new Map();
        allData.forEach(d=>wilayahMap.set(d["Kantor Pengawas"],(wilayahMap.get(d["Kantor Pengawas"])||0)+1));
        const topWilayah = Array.from(wilayahMap.entries()).sort((a,b)=>b[1]-a[1]).slice(0,6);
        if(charts.wilayah) charts.wilayah.destroy();
        charts.wilayah = new Chart(document.getElementById("wilayahChart"), { type:'bar', data:{ labels:topWilayah.map(w=>w[0]), datasets:[{ label:'Perusahaan', data:topWilayah.map(w=>w[1]), backgroundColor:'#10b981' }] }, options:{ plugins:{ datalabels:{ anchor:'end', align:'top', formatter:(v)=>v } }, responsive:true }, plugins:[ChartDataLabels] });
        
        const pembebasan = allData.filter(d=>d["Jenis NIPER"]==="PEMBEBASAN").length, pengembalian = allData.filter(d=>d["Jenis NIPER"]==="PENGEMBALIAN").length;
        if(charts.niper) charts.niper.destroy();
        charts.niper = new Chart(document.getElementById("niperChart"), { type:'doughnut', data:{ labels:['Pembebasan','Pengembalian'], datasets:[{ data:[pembebasan,pengembalian], backgroundColor:['#4f46e5','#ec489a'] }] }, options:{ plugins:{ datalabels:{ color:'white', formatter:(v)=>v } }, responsive:true }, plugins:[ChartDataLabels] });
    }
    
    function renderAll() { renderStats(); renderTable(document.getElementById("searchInput").value); updateCharts(); }
    
    function showDetail(data) {
        document.getElementById("detailContent").innerHTML = ALL_COLUMNS.map(c=>`<div class="form-field"><label>${c}</label><div><strong>${escapeHtml(data[c]||"-")}</strong></div></div>`).join("");
        document.getElementById("detailTitle").innerHTML = `<i class="fas fa-building"></i> ${escapeHtml(data["Nama Perusahaan"]||"")}`;
        document.getElementById("detailModal").style.display = "flex";
    }
    
    function openFormModal(data, isEdit, rowIndex) {
        document.getElementById("formTitle").innerHTML = isEdit ? "Edit Data" : "Tambah Data";
        document.getElementById("formFields").innerHTML = ALL_COLUMNS.map(c=>`<div class="form-field"><label>${c}</label><input type="text" id="f_${c.replace(/\s/g,'_')}" value="${escapeHtml(data ? (data[c]||"") : "")}"></div>`).join("");
        document.getElementById("formModal").style.display = "flex";
        document.getElementById("saveBtn").onclick = async () => {
            const newData = {};
            ALL_COLUMNS.forEach(c=>{ newData[c] = document.getElementById(`f_${c.replace(/\s/g,'_')}`).value; });
            const res = await callApi(isEdit ? "update" : "add", newData, rowIndex);
            if(res.success) { await loadData(); alert(res.message); closeModal("formModal"); }
            else alert("Gagal: "+res.message);
        };
    }
    
    async function editData(idx) { currentEditIndex = allData[idx]._id; showPasswordModal(()=>openFormModal(allData[idx], true, currentEditIndex)); }
    async function confirmDelete(idx) { showPasswordModal(async ()=>{ const res = await callApi("delete", null, allData[idx]._id); if(res.success) { await loadData(); alert(res.message); } else alert("Gagal: "+res.message); closeModal("passwordModal"); }); }
    function openAddData() { showPasswordModal(()=>openFormModal(null, false, null)); }
    
    function showPasswordModal(cb) { pendingCallback = cb; document.getElementById("passwordModal").style.display = "flex"; document.getElementById("adminPassword").value = ""; }
    function verifyPassword() { if(document.getElementById("adminPassword").value === ADMIN_PASSWORD) { localStorage.setItem("kite_password", ADMIN_PASSWORD); closeModal("passwordModal"); if(pendingCallback) pendingCallback(); pendingCallback=null; } else alert("Password salah!"); }
    function closeModal(id) { document.getElementById(id).style.display = "none"; }
    function escapeHtml(s) { if(!s) return ""; return String(s).replace(/[&<>]/g, (m)=>({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m])); }
    
    document.getElementById("openAddBtn").onclick = openAddData;
    document.getElementById("refreshBtn").onclick = loadData;
    document.getElementById("searchInput").oninput = (e)=>renderTable(e.target.value);
    document.getElementById("verifyPasswordBtn").onclick = verifyPassword;
    window.onclick = (e)=>{ if(e.target.classList.contains("modal")) e.target.style.display = "none"; };
    
    loadData();
</script>
</body>
</html>
